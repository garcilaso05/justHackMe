      "inputs": [
        {
          "key": "carpeta",
          "placeholder": "Nombre del directorio",
          "required": true,
          "mode": "replace"
        }
      ]
    }
  ],
  "winCondition": {
    "type": "stdout",
    "mode": "contains",
    "expected": "Bienvenido a justHackMe"
  },
  "hints": [
    {
      "unlockAfterSeconds": 10,
      "text": "Usa el bloque 'Listar directorio' para ver qué archivos hay."
    },
    {
      "unlockAfterSeconds": 15,
      "text": "Nota: las entradas que aparecen con nombre sin extensión (por ejemplo sin '.txt') son carpetas (directorios)."
    },
    {
      "unlockAfterSeconds": 25,
      "text": "Usa el bloque de lectura y escribe leeme.txt."
    }
