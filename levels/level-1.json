              "content": "rogergarciadoncel (CodeURV)"
            }
          }
        }
      }
    }
  },
  "blocks": [
    {
      "id": "ls",
      "label": "Listar directorio",
      "command": "ls",
      "description": "Muestra archivos y carpetas",
      "params": []
    },
    {
      "id": "cat",
      "label": "Leer contenido de un archivo",
      "command": "cat {archivo}",
