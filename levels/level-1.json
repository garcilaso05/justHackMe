      "params": [],
      "inputs": [
        {
          "key": "archivo",
          "placeholder": "Nombre del archivo",
          "required": true,
          "mode": "replace"
        }
      ]
    },
    {
      "id": "cd",
      "label": "Entrar a un directorio",
      "command": "cd {carpeta}",
      "description": "Cambia al directorio indicado",
